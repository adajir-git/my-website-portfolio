  <!-- HERO -->
  <section class="hero" id="hero">
    <div class="container">
      <p class="hero__label reveal">Linux Administrátor · VSHosting</p>
      <h1 class="hero__name reveal">Adam<br><span class="dim">Jiřík</span></h1>
      <p class="hero__desc reveal">
        Zajišťuji správu serverů, webovou infrastrukturu a síťové služby. 
        U technologií mě baví jít do hloubky a chápat, jak přesně systémy fungují. 
        Od enterprise prostředí v práci, přes <strong>self-hosted homelab</strong>, 
        až po návrh a bezpečnou správu infrastruktury pro <strong>reálné klienty a byznysy</strong>.
      </p>
      <div class="hero__cta reveal">
        <a href="#about" class="btn btn--primary">Služby & Spolupráce</a>
        <a href="https://github.com/adajir-git" target="_blank" class="btn btn--ghost">GitHub ↗</a>
        <a href="files/aji_cv.pdf" download class="btn btn--ghost">Stáhnout CV ↓</a>
      </div>
    </div>
    <div class="hero__bg-glow" aria-hidden="true"></div>
  </section>

  <!-- PROJECTS -->
  <section class="section" id="projects">
    <div class="container">
      <div class="section__header reveal">
        <span class="section__num">01</span>
        <h2>Projekty</h2>
        <div class="section__line"></div>
      </div>

      <div class="projects">

        <a class="project reveal" href="https://github.com/adajir-git/RaspberryPi-HomeLab" target="_blank">
          <div class="project__term-bar">
            <div class="project__dots">
              <span class="dot dot--red"></span>
              <span class="dot dot--yellow"></span>
              <span class="dot dot--green"></span>
            </div>
            <span class="project__term-title">homelab ~ bash</span>
          </div>
          <div class="project__body">
            <div class="project__top">
              <span class="project__title">Self-hosted Infrastruktura</span>
              <div class="project__top-right">
                <span class="badge badge--live">live</span>
                <span class="project__arrow">↗</span>
              </div>
            </div>
            <p class="project__desc">
              Dual-node self-hosted infrastruktura (Raspberry Pi 5 a Pi 2). Docker, Zero Trust networking, full observability stack:  Prometheus (node-exporter), Grafana. Běží 24/7.
            </p>
            <div class="project__insight">
              <span class="project__insight-label">výzva</span>
              Bezpečné vystavení služeb do internetu bez veřejné IP a bez otevírání portů.
            </div>
            <div class="project__insight">
              <span class="project__insight-label">řešení</span>
              Cloudflare Tunnels — Zero Trust architektura. Správa a přístup k uzlům přes Tailscale.
            </div>
            <div class="project__tags">
              <span class="tag">Linux</span>
              <span class="tag tag--blue">Docker</span>
              <span class="tag tag--blue">Networking</span>
              <span class="tag tag--blue">Prometheus</span>
              <span class="tag tag--blue">Grafana</span>
              <span class="tag tag--blue">Tailscale</span>
            </div>
          </div>
        </a>

        <a class="project reveal" href="https://github.com/adajir-git/cli-certificate-checker" target="_blank">
          <div class="project__term-bar">
            <div class="project__dots">
              <span class="dot dot--red"></span>
              <span class="dot dot--yellow"></span>
              <span class="dot dot--green"></span>
            </div>
            <span class="project__term-title">cert-checker ~ bash</span>
          </div>
          <div class="project__body">
            <div class="project__top">
              <span class="project__title">Custom Certificate Checker</span>
              <span class="project__arrow">↗</span>
            </div>
            <p class="project__desc">
            Vlastní skriptovaný nástroj pro kontrolu SSL/TLS certifikátů. Kontroluje expiraci a validitu dle domény a upozorňuje na blížící se konec platnosti.
            </p>
            <div class="project__tags">
              <span class="tag">Bash / Python</span>
              <span class="tag tag--blue">TLS/SSL</span>
              <span class="tag tag--blue">Monitoring</span>
            </div>
          </div>
        </a>

        <a class="project reveal" href="https://github.com/adajir-git/RISCV-Emulator" target="_blank">
          <div class="project__term-bar">
            <div class="project__dots">
              <span class="dot dot--red"></span>
              <span class="dot dot--yellow"></span>
              <span class="dot dot--green"></span>
            </div>
            <span class="project__term-title">riscv-emulator.py</span>
          </div>
          <div class="project__body">
            <div class="project__top">
              <span class="project__title">RISC-V Emulátor</span>
              <span class="project__arrow">↗</span>
            </div>
            <p class="project__desc">
              Emulátor procesoru (RV32I) napsaný v Pythonu jako semestrální projekt na MFF UK.
              Implementuje fetch-decode-execute cyklus, registry, paměťový model a unit testy podle oficiální ISA specifikace.
            </p>
            <div class="project__tags">
              <span class="tag">Python</span>
              <span class="tag tag--gray">low-level</span>
              <span class="tag tag--gray">Architektura</span>
            </div>
          </div>
        </a>

        <a class="project reveal" href="https://github.com/adajir-git/zednictvi-binder-web" target="_blank">
          <div class="project__term-bar">
            <div class="project__dots">
              <span class="dot dot--red"></span>
              <span class="dot dot--yellow"></span>
              <span class="dot dot--green"></span>
            </div>
            <span class="project__term-title">klient ~ http</span>
          </div>
          <div class="project__body">
            <div class="project__top">
              <span class="project__title">Firemní web: zednictvi-binder.cz</span>
              <div class="project__top-right">
                <span class="badge badge--live">live</span>
                <span class="project__arrow">↗</span>
              </div>
            </div>
            <p class="project__desc">
              Reálný klientský projekt — web pro lokální zednickou firmu.
              Od kompletního kódu v čistém HTML/SCSS/JS bez frameworků, až po zajištění domény a nasazení do produkce.
            </p>
            <div class="project__tags">
              <span class="tag">HTML/SCSS</span>
              <span class="tag">JavaScript</span>
              <span class="tag tag--gray">freelance</span>
              <span class="tag tag--gray">hosting</span>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

